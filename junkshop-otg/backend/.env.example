# Copy this file to .env and fill in your values:
#   cp .env.example .env   (Mac/Linux)
#   copy .env.example .env (Windows)

# MongoDB — local install or MongoDB Atlas connection string
MONGO_URI=mongodb://127.0.0.1:27017/junkshop_otg

# Secret for JWT tokens (use a long random string in production)
JWT_SECRET=change_this_to_a_long_random_secret

# Server port (frontend expects http://localhost:5000 by default)
PORT=5000

# Optional: extra comma-separated origins for CORS (localhost + *.vercel.app allowed in code)
# CLIENT_ORIGIN=http://localhost:5173,https://junkshop-on-the-go.vercel.app

# --- Password reset & notifications (SendGrid + Twilio) ---
# Email via SendGrid: https://sendgrid.com — verify sender email in SendGrid dashboard
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=hello@junkshop-otg.ph

# SMS via Twilio: https://twilio.com — use a Twilio number that can SMS to PH (+63)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Without the keys above, dev falls back to console logs + shows code in the UI.

# Seed catalog junkshops + materials (from repo root: npm run seed)
# Requires MONGO_URI and JWT_SECRET above.
