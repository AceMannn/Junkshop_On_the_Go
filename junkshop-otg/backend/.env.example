# Copy this file to .env and fill in your values:
#   cp .env.example .env   (Mac/Linux)
#   copy .env.example .env (Windows)

# MongoDB — local install or MongoDB Atlas connection string
MONGO_URI=mongodb://127.0.0.1:27017/junkshop_otg

# Secret for JWT tokens (use a long random string in production)
JWT_SECRET=change_this_to_a_long_random_secret

# Server port (frontend expects http://localhost:5000 by default)
PORT=5000

# Admin account created by seed script (npm run seed)
# ADMIN_EMAIL=admin@junkshop-otg.ph
# ADMIN_PASSWORD=AdminChangeMe123!

# Super Admin account created by seed script (npm run seed)
# SUPER_ADMIN_EMAIL=superadmin@junkshop-otg.ph
# SUPER_ADMIN_PASSWORD=SuperAdminChangeMe123!

# Optional: extra comma-separated origins for CORS (localhost + *.vercel.app allowed in code)
# CLIENT_ORIGIN=https://your-public-site.vercel.app
# ADMIN_PORTAL_ORIGIN=https://junkshop-admin.vercel.app
# SUPER_ADMIN_PORTAL_ORIGIN=https://junkshop-super-admin.vercel.app

# --- Deploy checklist (3 apps, 1 backend) ---
# Render: backend/  → set MONGO_URI, JWT_SECRET, CLIENT_ORIGIN, ADMIN_PORTAL_ORIGIN, SUPER_ADMIN_PORTAL_ORIGIN
# Vercel #1: frontend/  → VITE_API_BASE_URL=https://your-api.onrender.com
# Vercel #2: admin-portal/  → VITE_API_BASE_URL=https://your-api.onrender.com
# Vercel #3: super-admin-portal/  → VITE_API_BASE_URL=https://your-api.onrender.com
# After deploy: npm run smoke (against live API with SMOKE_BASE_URL)

# --- Password reset & notifications (Brevo email + SMS) ---
# Email via Brevo: https://brevo.com — verify sender email/domain in Brevo first.
# Without BREVO_API_KEY, signup verification + password reset codes log to the backend console
# and appear in the API response as devVerificationCode (non-production only).
BREVO_API_KEY=
BREVO_FROM_EMAIL=hello@junkshop-otg.ph
BREVO_FROM_NAME=JunkShop On-The-Go

# SMS via Brevo transactional SMS. Sender must be 11 alphanumeric characters or fewer.
BREVO_SMS_SENDER=JunkShopOTG

# Without the email keys above, dev email falls back to console logs + shows code in the UI.

# Seed catalog junkshops + materials (from repo root: npm run seed)
# Requires MONGO_URI and JWT_SECRET above.
